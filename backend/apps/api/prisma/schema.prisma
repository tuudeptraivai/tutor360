// Minimal Prisma schema for V02 skeleton.
// Chỉ chứa generator + datasource để PrismaService (Slide 9) compile và
// chạy `SELECT 1` ở /health. Các model domain sẽ được bổ sung ở issue Prisma schema.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// TODO: xoá khi issue Prisma schema thêm model domain thật.
// Placeholder để `prisma generate` chạy được; PrismaService chỉ cần $connect + $queryRaw cho /health.
model Placeholder {
  id Int @id @default(autoincrement())
}
