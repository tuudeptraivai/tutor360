# ---- App ----
PORT=3000
NODE_ENV=development

# Comma-separated whitelist of allowed CORS origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ---- Database (Prisma) ----
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tutor365?schema=public

# ---- Auth (JWT) — secrets phải >= 32 ký tự (fail-fast khi boot) ----
JWT_ACCESS_SECRET=change-me-access-secret-min-32-characters
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-characters

# ---- VNPay ----
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=

# ---- Mail (SMTP / MailPit dev) ----
# Dev: chạy MailPit qua `docker compose -f backend/docker-compose.yml up -d mailpit`
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@tutor365.local

# Base URL dùng để build link verify trong email
APP_URL=http://localhost:3000

# ---- Auth tuning ----
# Bcrypt cost: production 12; có thể hạ xuống 4 trong test để hash nhanh
BCRYPT_COST=12
# Verify token TTL (giờ)
VERIFY_TOKEN_TTL_HOURS=24
