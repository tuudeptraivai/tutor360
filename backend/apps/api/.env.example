# ---- App ----
PORT=3000
NODE_ENV=development

# Comma-separated whitelist of allowed CORS origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ---- Database (Prisma) ----
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tutor365?schema=public

# ---- Auth (JWT) — secrets phải >= 32 ký tự (fail-fast khi boot) ----
JWT_ACCESS_SECRET=change-me-access-secret-min-32-characters
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-characters

# ---- VNPay ----
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
