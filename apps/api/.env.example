# ---- App ----
PORT=3000
NODE_ENV=development

# Comma-separated whitelist of allowed CORS origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ---- Database (Prisma) ----
# Chưa dùng ở phase scaffold, sẽ cấu hình ở issue Prisma schema
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tutor365?schema=public

# ---- Auth (JWT) ----
JWT_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret

# ---- VNPay ----
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
